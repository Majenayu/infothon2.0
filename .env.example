# ============================================================
#  EcoRoute — Environment Variables
#  Copy this file to ".env" and fill in your values
# ============================================================

# MongoDB connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
# Local:   mongodb://localhost:27017/ecoroute
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/ecoroute
MONGO_URI=mongodb://localhost:27017/ecoroute

# JWT Secret — change this to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret

# Server port (default: 3000)
PORT=3000
